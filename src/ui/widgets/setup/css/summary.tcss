SetupSummary {
    width: 1fr;
    min-width: 68;
    height: auto;
    margin-top: 0;
    margin-bottom: 1;
    background: $background;
}

SetupSummary #summary_title {
    height: 1;
    width: 1fr;
    color: $accent;
    text-style: bold;
    overflow: hidden;
}

SetupSummary #summary_body {
    height: 1;
    margin-left: 2;
    color: $foreground;
    overflow: hidden;
}