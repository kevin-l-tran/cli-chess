SetupScreen { 
    align: center middle; 
}

#panel {
    width: auto;
    height: auto;
    max-width: 120;
    max-height: 35;
    padding: 2 4;
    border: round $border;
    background: $panel;
}

#title {
    content-align: center middle;
    text-style: bold;
    height: auto;
}

#subtitle {
    content-align: center middle;
    color: $text-muted;
    margin-bottom: 1;
    height: auto;
}